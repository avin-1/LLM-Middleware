            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello, this is a test message\",\n  \"profile\": \"standard\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/analyze",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "analyze"]
            },
            "description": "Basic text analysis with standard profile"
          },
          "response": []
        },
