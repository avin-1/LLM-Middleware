                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"SELECT * FROM users WHERE id = 1 OR 1=1\",\n  \"profile\": \"standard\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/analyze",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "analyze"]
            },
            "description": "Test SQL injection detection"
          },
          "response": []
        },
        {
          "name": "Analyze Text - With Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello world\",\n  \"profile\": \"standard\",\n  \"session_id\": \"user-123-session-456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/analyze",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "analyze"]
            },
            "description": "Analysis with session tracking"
          },
          "response": []
        },
        {
          "name": "Analyze Batch",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/analyze/batch?texts=Hello&texts=World&texts=Test&profile=standard",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "analyze", "batch"],
              "query": [
                {
                  "key": "texts",
                  "value": "Hello"
                },
                {
                  "key": "texts",
                  "value": "World"
                },
                {
                  "key": "texts",
                  "value": "Test"
                },
                {
                  "key": "profile",
                  "value": "standard"
                }
              ]
            },
            "description": "Batch analysis of multiple texts"
          },
          "response": []
        }
      ]
